<?xml version="1.0"?>
<robot name="axol">
  <link name="world"></link>

  <!-- Base -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.01 0.01 0.01"/>
      </geometry>
      <material name="black">
        <color rgba="0.0 0.0 0.0 1.0"/>
      </material>
    </visual>
  </link>

  <joint name="base_joint" type="fixed">
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <parent link="world"/>
    <child link="base_link"/>
  </joint>

  <!-- ========== LEFT ARM (from base_link) ========== -->

  <link name="left_shoulder_1_link">
    <visual>
      <geometry><box size="0.05 0.05 0.05"/></geometry>
      <material name="blue"><color rgba="0.0 0.0 1.0 1.0"/></material>
    </visual>
  </link>
  <joint name="left_shoulder_1_joint" type="revolute">
    <parent link="base_link"/>
    <child link="left_shoulder_1_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 -1 0"/>
    <limit lower="-1.5708" upper="3.1416" effort="10" velocity="1.0"/>
  </joint>

  <link name="left_shoulder_2_link">
    <visual>
      <geometry><box size="0.05 0.05 0.05"/></geometry>
      <material name="blue"><color rgba="0.0 0.0 1.0 1.0"/></material>
    </visual>
  </link>
  <joint name="left_shoulder_2_joint" type="revolute">
    <parent link="left_shoulder_1_link"/>
    <child link="left_shoulder_2_link"/>
    <origin xyz="0.075 0 0" rpy="0 0 0"/>
    <axis xyz="-1 0 0"/>
    <limit lower="-0.349066" upper="3.1416" effort="10" velocity="1.0"/>
  </joint>

  <link name="left_shoulder_3_link">
    <visual>
      <geometry><box size="0.05 0.05 0.05"/></geometry>
      <material name="blue"><color rgba="0.0 0.0 1.0 1.0"/></material>
    </visual>
  </link>
  <joint name="left_shoulder_3_joint" type="revolute">
    <parent link="left_shoulder_2_link"/>
    <child link="left_shoulder_3_link"/>
    <origin xyz="0 0 -0.145" rpy="0 0 0"/>
    <axis xyz="0 0 -1"/>
    <limit lower="-1.5708" upper="1.5708" effort="10" velocity="1.0"/>
  </joint>

  <link name="left_elbow_link">
    <visual>
      <geometry><box size="0.05 0.05 0.05"/></geometry>
      <material name="green"><color rgba="0.0 1.0 0.0 1.0"/></material>
    </visual>
  </link>
  <joint name="left_elbow_joint" type="revolute">
    <parent link="left_shoulder_3_link"/>
    <child link="left_elbow_link"/>
    <origin xyz="0 0 -0.22" rpy="0 0 0"/>
    <axis xyz="-1 0 0"/>
    <limit lower="0" upper="2.27" effort="10" velocity="1.0"/>
  </joint>

  <link name="left_wrist_1_link">
    <visual>
      <geometry><box size="0.05 0.05 0.05"/></geometry>
      <material name="red"><color rgba="1.0 0.0 0.0 1.0"/></material>
    </visual>
  </link>
  <joint name="left_wrist_1_joint" type="revolute">
    <parent link="left_elbow_link"/>
    <child link="left_wrist_1_link"/>
    <origin xyz="0 0 -0.125" rpy="0 0 0"/>
    <axis xyz="0 0 -1"/>
    <limit lower="-1.5708" upper="1.5708" effort="10" velocity="1.0"/>
  </joint>

  <link name="left_wrist_2_link">
    <visual>
      <geometry><box size="0.05 0.05 0.05"/></geometry>
      <material name="red"><color rgba="1.0 0.0 0.0 1.0"/></material>
    </visual>
  </link>
  <joint name="left_wrist_2_joint" type="revolute">
    <parent link="left_wrist_1_link"/>
    <child link="left_wrist_2_link"/>
    <origin xyz="0 0 -0.25" rpy="0 0 0"/>
    <axis xyz="-1 0 0"/>
    <limit lower="-1.5708" upper="1.5708" effort="10" velocity="1.0"/>
  </joint>

  <link name="left_wrist_3_link">
    <visual>
      <geometry><box size="0.05 0.05 0.05"/></geometry>
      <material name="red"><color rgba="1.0 0.0 0.0 1.0"/></material>
    </visual>
  </link>
  <joint name="left_wrist_3_joint" type="revolute">
    <parent link="left_wrist_2_link"/>
    <child link="left_wrist_3_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 -1 0"/>
    <limit lower="-0.35" upper="0.35" effort="10" velocity="1.0"/>
  </joint>

  <link name="left_ee_link">
    <visual>
      <geometry><box size="0.05 0.05 0.05"/></geometry>
      <material name="blue"><color rgba="0.0 0.0 1.0 1.0"/></material>
    </visual>
  </link>
  <joint name="left_ee_joint" type="fixed">
    <parent link="left_wrist_3_link"/>
    <child link="left_ee_link"/>
    <origin xyz="0 0 -0.075" rpy="3.141592653589793 0 -1.5707963267948966"/>
  </joint>

  <!-- ========== RIGHT ARM (from base_link, mirrored in X) ========== -->

  <link name="right_shoulder_1_link">
    <visual>
      <geometry><box size="0.05 0.05 0.05"/></geometry>
      <material name="blue"><color rgba="0.0 0.0 1.0 1.0"/></material>
    </visual>
  </link>
  <joint name="right_shoulder_1_joint" type="revolute">
    <parent link="base_link"/>
    <child link="right_shoulder_1_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.5708" upper="3.1416" effort="10" velocity="1.0"/>
  </joint>

  <link name="right_shoulder_2_link">
    <visual>
      <geometry><box size="0.05 0.05 0.05"/></geometry>
      <material name="blue"><color rgba="0.0 0.0 1.0 1.0"/></material>
    </visual>
  </link>
  <joint name="right_shoulder_2_joint" type="revolute">
    <parent link="right_shoulder_1_link"/>
    <child link="right_shoulder_2_link"/>
    <origin xyz="-0.075 0 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-3.1416" upper="0.349066" effort="10" velocity="1.0"/>
  </joint>

  <link name="right_shoulder_3_link">
    <visual>
      <geometry><box size="0.05 0.05 0.05"/></geometry>
      <material name="blue"><color rgba="0.0 0.0 1.0 1.0"/></material>
    </visual>
  </link>
  <joint name="right_shoulder_3_joint" type="revolute">
    <parent link="right_shoulder_2_link"/>
    <child link="right_shoulder_3_link"/>
    <origin xyz="0 0 -0.145" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.5708" upper="1.5708" effort="10" velocity="1.0"/>
  </joint>

  <link name="right_elbow_link">
    <visual>
      <geometry><box size="0.05 0.05 0.05"/></geometry>
      <material name="green"><color rgba="0.0 1.0 0.0 1.0"/></material>
    </visual>
  </link>
  <joint name="right_elbow_joint" type="revolute">
    <parent link="right_shoulder_3_link"/>
    <child link="right_elbow_link"/>
    <origin xyz="0 0 -0.22" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-2.27" upper="0" effort="10" velocity="1.0"/>
  </joint>

  <link name="right_wrist_1_link">
    <visual>
      <geometry><box size="0.05 0.05 0.05"/></geometry>
      <material name="red"><color rgba="1.0 0.0 0.0 1.0"/></material>
    </visual>
  </link>
  <joint name="right_wrist_1_joint" type="revolute">
    <parent link="right_elbow_link"/>
    <child link="right_wrist_1_link"/>
    <origin xyz="0 0 -0.125" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.5708" upper="1.5708" effort="10" velocity="1.0"/>
  </joint>

  <link name="right_wrist_2_link">
    <visual>
      <geometry><box size="0.05 0.05 0.05"/></geometry>
      <material name="red"><color rgba="1.0 0.0 0.0 1.0"/></material>
    </visual>
  </link>
  <joint name="right_wrist_2_joint" type="revolute">
    <parent link="right_wrist_1_link"/>
    <child link="right_wrist_2_link"/>
    <origin xyz="0 0 -0.25" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-1.5708" upper="1.5708" effort="10" velocity="1.0"/>
  </joint>

  <link name="right_wrist_3_link">
    <visual>
      <geometry><box size="0.05 0.05 0.05"/></geometry>
      <material name="red"><color rgba="1.0 0.0 0.0 1.0"/></material>
    </visual>
  </link>
  <joint name="right_wrist_3_joint" type="revolute">
    <parent link="right_wrist_2_link"/>
    <child link="right_wrist_3_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.35" upper="0.35" effort="10" velocity="1.0"/>
  </joint>

  <link name="right_ee_link">
    <visual>
      <geometry><box size="0.05 0.05 0.05"/></geometry>
      <material name="blue"><color rgba="0.0 0.0 1.0 1.0"/></material>
    </visual>
  </link>
  <joint name="right_ee_joint" type="fixed">
    <parent link="right_wrist_3_link"/>
    <child link="right_ee_link"/>
    <origin xyz="0 0 -0.075" rpy="3.141592653589793 0 -1.5707963267948966"/>
  </joint>
</robot>
